APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ---------------------------------------------------------------------------
# Production (e.g. DigitalOcean App Platform)
# ---------------------------------------------------------------------------
# Set APP_KEY to a base64 key (php artisan key:generate --show). Never commit .env.
# Docker images must not generate APP_KEY at build time — configure APP_KEY as a runtime secret on
# the platform so cookies/session encryption stay consistent and rotatable per environment.
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.ondigitalocean.app
# LOG_CHANNEL=stderr
# Trust X-Forwarded-* from the platform load balancer. Use * or a comma-separated list of IPs.
# TRUSTED_PROXIES=*
# Database: on App Platform, bind component env vars to DB_* (see .do/app.yaml) or set DB_URL.
# FRONTEND_URL and SANCTUM_STATEFUL_DOMAINS should match your public site / SPA origin (not localhost).
# ---------------------------------------------------------------------------

# AI visitor chat (optional floating widget on public site when slug is set)
AI_CHAT_ENABLED=true
AI_WIDGET_AGENT_SLUG=
# Optional: dedicated agent for /get-started intake (falls back to AI_WIDGET_AGENT_SLUG)
AI_INTAKE_AGENT_SLUG=

# Public lead intake (/get-started): rate limits & optional IP geolocation
INTAKE_RATE_LIMIT_PER_MINUTE=8
INTAKE_RATE_LIMIT_PER_DAY=40
INTAKE_GEO_ENABLED=false
# ip_api (no token) or ipinfo (set IPINFO_TOKEN for production)
INTAKE_GEO_DRIVER=ip_api
IPINFO_TOKEN=

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artixcore
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disk for Spatie Media Library (public for local URLs via storage:link; use s3 in production)
MEDIA_DISK=public
# Optional absolute URL for users without an uploaded avatar
DEFAULT_AVATAR_URL=

QUEUE_CONNECTION=database

CACHE_STORE=database
# For faster SEO settings reads in production, use Redis: CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

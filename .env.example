APP_NAME=Laravel
# Production (reference): APP_ENV=production, APP_DEBUG=false, APP_URL=https://artixcore.com
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: https://artixcore.com — local dev may use http://localhost:8000
APP_URL=https://artixcore.com

# ---------------------------------------------------------------------------
# Session (production behind HTTPS)
# ---------------------------------------------------------------------------
# SESSION_SECURE_COOKIE=true
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=lax

# ---------------------------------------------------------------------------
# Application rate limits (used by config/rate_limiting.php)
# ---------------------------------------------------------------------------
# RATE_LIMIT_PUBLIC_PER_MINUTE=120
# RATE_LIMIT_FORMS_PER_MINUTE=5
# RATE_LIMIT_LOGIN_PER_MINUTE=5
# RATE_LIMIT_AI_CHAT_PER_MINUTE=10
# RATE_LIMIT_API_GUEST_PER_MINUTE=120
# RATE_LIMIT_API_AUTHENTICATED_PER_MINUTE=300
# RATE_LIMIT_ANALYTICS_PER_MINUTE=60

# Lead form timing anti-bot (seconds; bypass only for tests/automation)
# FORM_TIMING_MIN_SECONDS=2
# FORM_TIMING_BYPASS=false

# ---------------------------------------------------------------------------
# Production (e.g. DigitalOcean App Platform)
# ---------------------------------------------------------------------------
# Set APP_KEY to a base64 key (php artisan key:generate --show). Never commit .env.
# Docker images must not generate APP_KEY at build time — configure APP_KEY as a runtime secret on
# the platform so cookies/session encryption stay consistent and rotatable per environment.
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.ondigitalocean.app
# LOG_CHANNEL=stderr
# Trust X-Forwarded-* from the platform load balancer. Use * or a comma-separated list of IPs.
# TRUSTED_PROXIES=*
# Database: on App Platform, bind component env vars to DB_* (see .do/app.yaml) or set DB_URL.
# FRONTEND_URL and SANCTUM_STATEFUL_DOMAINS should match your public site / SPA origin (not localhost).
# ---------------------------------------------------------------------------

# AI visitor chat (optional floating widget on public site when slug is set)
AI_CHAT_ENABLED=true
AI_WIDGET_AGENT_SLUG=
# Optional: dedicated agent for /get-started intake (falls back to AI_WIDGET_AGENT_SLUG)
AI_INTAKE_AGENT_SLUG=

# AI content engine (Ali 1.0 drafts — optional; never commit real keys)
OPENAI_API_KEY=
OPENAI_ARTICLE_MODEL=gpt-4.1-mini
AI_CONTENT_AUTHOR="Ali 1.0"
AI_ARTICLE_AUTHOR="Ali 1.0"
AI_ARTICLE_AUTO_PUBLISH=false
AI_ARTICLE_DEFAULT_STATUS=pending_review
AI_ARTICLE_DAILY_LIMIT=3

AI_CASE_STUDY_ENABLED=true
AI_CASE_STUDY_INTERVAL_DAYS=2
AI_CASE_STUDY_DAILY_LIMIT=1
AI_CASE_STUDY_AUTO_PUBLISH=false

AI_MARKET_UPDATE_ENABLED=true
AI_MARKET_UPDATE_INTERVAL_DAYS=2
AI_MARKET_UPDATE_DAILY_LIMIT=1
AI_MARKET_UPDATE_AUTO_PUBLISH=false

# Optional future integrations (placeholders; not required for generation)
NEWS_API_KEY=
MARKET_DATA_API_KEY=
PLAGIARISM_CHECKER_API_KEY=
ARTICLE_FALLBACK_IMAGE_URL=

# Public lead intake (/get-started): rate limits & optional IP geolocation
INTAKE_RATE_LIMIT_PER_MINUTE=8
INTAKE_RATE_LIMIT_PER_DAY=40
INTAKE_GEO_ENABLED=false
# ip_api (no token) or ipinfo (set IPINFO_TOKEN for production)
INTAKE_GEO_DRIVER=ip_api
IPINFO_TOKEN=

# CRM / public forms: unified GeoIP toggle (also respects INTAKE_GEO_ENABLED). Never log tokens.
GEOIP_ENABLED=false
# Cache successful lookups (seconds)
GEOIP_CACHE_TTL=86400

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Canonical public site URL (also drives Storage disk URLs). Local dev may override to http://localhost:8000.
ASSET_URL=

# Public marketing contact (used by ProductionContactInfoSeeder when fixing legacy placeholders)
CONTACT_EMAIL=hello@artixcore.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artixcore
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Media Library disk: "public" for local dev (requires storage:link). On DigitalOcean App Platform use "spaces"
# with AWS_* below so uploads survive redeploys; local ephemeral storage is not durable on DO.
MEDIA_DISK=public
# Optional absolute URL for users without an uploaded avatar
DEFAULT_AVATAR_URL=

QUEUE_CONNECTION=database

CACHE_STORE=database
# For faster SEO settings reads in production, use Redis: CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@artixcore.com"
MAIL_FROM_NAME="${APP_NAME}"

# CRM outbound email from /admin/crm (disable to show friendly errors without throwing)
CRM_EMAIL_ENABLED=true
# Optional default assignee user id for auto-created CRM contacts from the website lead form
CRM_DEFAULT_ASSIGNEE_ID=

# Lead form (optional notification when mail is configured)
LEADS_NOTIFICATION_EMAIL=hello@artixcore.com

# Captcha (public /lead form). CAPTCHA_DRIVER: turnstile | recaptcha_v2. Fail closed in production.
# Same env vars populate config('services.turnstile.*') (site/secret/bypass) for third-party config consistency.
CAPTCHA_DRIVER=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Local/testing only: skip server-side verification (CaptchVerifier::allowsBypass still requires local|testing)
TURNSTILE_BYPASS=false
# Legacy: used only if TURNSTILE_BYPASS is not set in the environment
# CAPTCHA_BYPASS=false

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# S3 / DigitalOcean Spaces (optional; required when MEDIA_DISK=spaces)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=nyc3
AWS_BUCKET=
AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Blade admin / master (IP allowlist, split login)
FILAMENT_PANEL_ENABLED=false
FILAMENT_LEGACY_REDIRECT=admin_login
ADMIN_IP_ALLOWLIST_BYPASS=false
ADMIN_LOGIN_RATE_LIMIT=5
MASTER_LOGIN_RATE_LIMIT=3
# Optional: create master admin on seed (never commit real passwords)
# MASTER_ADMIN_EMAIL=
# MASTER_ADMIN_PASSWORD=
# ADMIN_2FA_ENABLED=false
# MASTER_2FA_REQUIRED=false

VITE_APP_NAME="${APP_NAME}"

# Dependency audits (run periodically in CI or locally): composer audit ; npm audit

# ---------------------------------------------------------------------------
# CRM / Blade admin (after pulling CRM changes)
# ---------------------------------------------------------------------------
# Local setup (typical): composer install ; npm ci ; npm run build ; php artisan migrate
# Verify routes: php artisan route:list --path=admin/crm
# Run tests: php artisan test
# Optional demo data (idempotent): php artisan db:seed --class=ArtixcoreCrmSeeder
# Production deploy (never migrate:fresh on real data): php artisan migrate --force
# Then targeted seed if needed: php artisan db:seed --class=ArtixcoreCrmSeeder --force
# Clear and warm caches: php artisan optimize:clear ; php artisan config:cache ; php artisan route:cache ; php artisan view:cache
# If queues process mail/jobs: php artisan queue:restart

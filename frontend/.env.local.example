NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Backend: set FRONTEND_URL to the same origin you use in the browser (e.g. http://localhost:3000) for CORS.
# Keep NEXT_PUBLIC_API_URL's hostname consistent with how you open the Laravel app (localhost vs 127.0.0.1) to avoid confusion in local dev.
# Optional: override default Artixcore logo (favicon, navbar, OG)
# NEXT_PUBLIC_SITE_LOGO_URL=https://example.com/logo.png
# Optional: ad network placement id for Micro Tools (guests only in UI)
# NEXT_PUBLIC_MICRO_TOOLS_AD_SLOT=

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Backend: set FRONTEND_URL to this site URL and SANCTUM_STATEFUL_DOMAINS to match (see repo .env.example)
# so browser POSTs to the API (e.g. micro tool run) pass CSRF with credentials.
# Optional: override default Artixcore logo (favicon, navbar, OG)
# NEXT_PUBLIC_SITE_LOGO_URL=https://example.com/logo.png
# Optional: ad network placement id for Micro Tools (guests only in UI)
# NEXT_PUBLIC_MICRO_TOOLS_AD_SLOT=
